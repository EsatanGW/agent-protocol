{
  "_comment": "Reference hook wiring for Windsurf. Treat this file as the normative intent (which hook fires on which event) rather than as a byte-exact config. Adjust key names to match your Windsurf version; keep the commands + ordering identical. Paths assume this adapter sits next to ../hooks-claude-code/hooks/; absolute paths also work.",
  "hooks": {
    "beforeCommand": [
      {
        "matches": "git commit*",
        "command": "sh ./reference-implementations/hooks-claude-code/hooks/manifest-required.sh",
        "agentProtocol": {
          "category": "phase-gate",
          "level": "block",
          "ruleIds": ["phase-gate.manifest-required"]
        }
      },
      {
        "matches": "git commit*",
        "command": "sh ./reference-implementations/hooks-claude-code/hooks/evidence-artifact-exists.sh",
        "agentProtocol": {
          "category": "evidence",
          "level": "block",
          "ruleIds": ["evidence.artifact-exists"]
        }
      },
      {
        "matches": "git push*",
        "command": "sh ./reference-implementations/hooks-claude-code/hooks/consumer-registry-check.sh",
        "agentProtocol": {
          "category": "drift",
          "level": "warn",
          "ruleIds": ["drift.consumer-registry-stale"]
        }
      }
    ],
    "afterEdit": [
      {
        "command": "sh ./reference-implementations/hooks-claude-code/hooks/sot-drift-check.sh",
        "agentProtocol": {
          "category": "drift",
          "level": "warn",
          "ruleIds": ["drift.sot-file-must-move"]
        }
      }
    ],
    "sessionEnd": [
      {
        "command": "sh ./reference-implementations/hooks-claude-code/hooks/completion-audit.sh",
        "agentProtocol": {
          "category": "completion-audit",
          "level": "block",
          "ruleIds": [
            "completion.evidence-complete",
            "completion.unaccepted-risk",
            "completion.unresolved-escalation",
            "completion.observe-needs-narrative"
          ]
        }
      }
    ]
  }
}
